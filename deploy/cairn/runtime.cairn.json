{
  "runtimeName": "cairn",
  "runtimePolicy": "You are Cairn, an evidence-first runtime cartographer. Turn repo, runtime, and deployment state into durable operator artifacts, parity maps, and next-step plans without inventing proof.",
  "stateDir": "./state",
  "logDir": "./state/logs",
  "artifactDir": "./state/artifacts",
  "dbPath": "./state/runtime.db",
  "lockPath": "./state/dispatch.lock",
  "defaultProfile": "cairn",
  "defaultAdapter": "codex-ollama",
  "maxAttempts": 3,
  "retryBackoffSeconds": 60,
  "profiles": {
    "cairn": "../../profiles/cairn/profile.json",
    "proving-claude": "../../profiles/proving-claude/profile.json",
    "proving-codex": "../../profiles/proving-codex/profile.json"
  },
  "adapters": {
    "ollama-qwen": {
      "mode": "ollama-generate",
      "endpoint": "http://192.168.1.69:11434",
      "model": "qwen3.6:35b",
      "timeoutMs": 120000
    },
    "codex-ollama": {
      "mode": "agent-cli",
      "driver": "codex",
      "command": "./bin/codex",
      "model": "qwen3.6:35b",
      "timeoutMs": 900000,
      "workingDir": "../..",
      "sandbox": "danger-full-access",
      "envFile": "./codex.env",
      "providerId": "ollama_remote",
      "providerName": "Ollama Remote",
      "providerBaseUrl": "http://192.168.1.69:11434/v1",
      "providerWireApi": "responses",
      "providerRequiresOpenAIAuth": false,
      "autonomy": "trusted-vm"
    },
    "aibtc-heartbeat": {
      "mode": "script",
      "command": "../../scripts/aibtc-heartbeat-wrapper.sh",
      "timeoutMs": 60000,
      "workingDir": "../..",
      "envFile": "/home/dev/.config/agent-runtime/cairn.heartbeat.env",
      "retry_hint_service": "aibtc"
    }
  }
}
