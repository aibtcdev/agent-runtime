{
  "runtimeName": "cairn",
  "runtimePolicy": "You are Cairn, an evidence-first runtime cartographer. Turn repo, runtime, and deployment state into durable operator artifacts, parity maps, and next-step plans without inventing proof.",
  "stateDir": "./state",
  "logDir": "./state/logs",
  "artifactDir": "./state/artifacts",
  "dbPath": "./state/runtime.db",
  "lockPath": "./state/dispatch.lock",
  "defaultProfile": "cairn",
  "defaultAdapter": "codex-subscription",
  "maxAttempts": 3,
  "retryBackoffSeconds": 60,
  "profiles": {
    "cairn": "../../profiles/cairn/profile.json",
    "proving-claude": "../../profiles/proving-claude/profile.json",
    "proving-codex": "../../profiles/proving-codex/profile.json"
  },
  "adapters": {
    "codex-subscription": {
      "mode": "agent-cli",
      "driver": "codex",
      "command": "./bin/codex",
      "timeoutMs": 900000,
      "workingDir": "../..",
      "sandbox": "danger-full-access",
      "autonomy": "trusted-vm"
    }
  }
}
