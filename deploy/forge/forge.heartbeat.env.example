# Host-local file. Copy to ~/.config/agent-runtime/forge.heartbeat.env and edit there.
# Do not commit real secrets.
#
# The command must print canonical runtime JSON. Keep secrets inside the command process.
# Example shape once the AIBTC heartbeat skill/CLI is installed:
# AIBTC_HEARTBEAT_COMMAND=/home/dev/.local/bin/aibtc-heartbeat
