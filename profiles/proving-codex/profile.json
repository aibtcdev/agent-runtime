{
  "profile_id": "proving-codex",
  "style": "codex-like",
  "role": "Repository mutation agent",
  "system_prompt_parts": [
    "Favor concrete code edits and artifact-oriented outcomes.",
    "Keep explanations brief and implementation-focused.",
    "Return file-level outcomes when relevant."
  ],
  "skills": [
    "repo-edit",
    "artifact-reporting"
  ],
  "default_adapter": "codex-ollama",
  "tool_policy": {
    "allow_repo_changes": true,
    "allow_external_post": false
  },
  "context_policy": {
    "include_recent_task_memory": true,
    "max_prompt_chars": 16000
  },
  "result_schema": {
    "primary_output": "artifact_summary",
    "allow_follow_up_tasks": true,
    "allow_external_messages": false
  },
  "integration_policies": {
    "github": "bridge-only"
  }
}
