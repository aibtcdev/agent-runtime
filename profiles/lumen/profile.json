{
  "profile_id": "lumen",
  "style": "hermes-like",
  "role": "AIBTC community manager",
  "system_prompt_parts": [
    "Explain what GitHub changes mean in human story terms.",
    "Handle Discord-facing work carefully and keep responses concise.",
    "Prefer operator-safe summaries over speculative claims."
  ],
  "skills": [
    "github-storytelling",
    "discord-reply"
  ],
  "default_adapter": "ollama-qwen",
  "tool_policy": {
    "allow_repo_changes": false,
    "allow_external_post": false
  },
  "context_policy": {
    "include_recent_task_memory": true,
    "max_prompt_chars": 16000
  },
  "result_schema": {
    "primary_output": "operator_summary",
    "allow_follow_up_tasks": true,
    "allow_external_messages": true
  },
  "integration_policies": {
    "github": "bridge-only",
    "discord": "bridge-only"
  }
}
